# PostgreSQL (Railway la genera automaticamente al crear el servicio)
DATABASE_URL="postgresql://user:password@host:5432/reviewtap"

# Genera uno con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-seguro"

# URL publica de la app (sin slash final). En Railway: https://tuapp.up.railway.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# "true" solo para crear la primera cuenta admin. Luego ponlo en "false".
ALLOW_REGISTER="true"

# Requerido por Auth.js detras de proxy (Railway)
AUTH_TRUST_HOST="true"
